/**
 * Bangla Web Fonts - Local @font-face declarations
 * Fonts bundled inside the plugin for offline use.
 * Source: https://github.com/maateen/bangla-web-fonts (GPL-2.0 licensed)
 */

/* SolaimanLipi */
@font-face {
    font-family: 'SolaimanLipi';
    src: url('../fonts/solaimanlipi-normal-v1.0.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
}
@font-face {
    font-family: 'SolaimanLipi';
    src: url('../fonts/solaimanlipi-bold-v1.0.ttf') format('truetype');
    font-weight: bold;
    font-style: normal;
    font-display: swap;
}

